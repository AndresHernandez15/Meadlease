# ============================================================
# VARIABLES DE ENTORNO — ATLAS (PLANTILLA)
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores con tus propias API keys.
# 3. NUNCA subas el archivo .env al repositorio.

# ── Groq (LLM + STT) — https://console.groq.com/keys ────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_BACKUP=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Azure Speech (TTS) — https://portal.azure.com ───────────
AZURE_SPEECH_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SPEECH_REGION=eastus

# ── Porcupine (Wake Word) — https://console.picovoice.ai ────
PORCUPINE_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

